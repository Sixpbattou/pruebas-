{
  "name": "FitSync Coach & Client Platform",
  "short_name": "FitSync",
  "description": "Plataforma SaaS profesional de gestión para entrenadores personales con IA y sincronización en tiempo real.",
  "id": "/",
  "scope": "/",
  "start_url": "/",
  "lang": "es-ES",
  "dir": "ltr",
  "display": "standalone",
  "background_color": "#0a0a0a",
  "theme_color": "#10b981",
  "orientation": "portrait",
  "categories": ["fitness", "sports", "productivity"],
  "iarc_rating_id": "e963b53f-a367-4fb8-8575-80252e18d6bc",
  "prefer_related_applications": false,
  "related_applications": [],
  "icons": [
    {
      "src": "/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshot-mobile.jpg",
      "sizes": "768x1376",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "FitSync Mobile Coach View"
    },
    {
      "src": "/screenshot-desktop.jpg",
      "sizes": "1376x768",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "FitSync Desktop Administration Panel"
    }
  ],
  "shortcuts": [
    {
      "name": "Ver Clientes",
      "short_name": "Clientes",
      "description": "Acceso rápido al listado de clientes activos",
      "url": "/?tab=clientes",
      "icons": [{ "src": "/icon.svg", "sizes": "any", "type": "image/svg+xml" }]
    },
    {
      "name": "Administrar Suscripciones",
      "short_name": "Suscripciones",
      "description": "Ver pagos y planes de Stripe",
      "url": "/?tab=facturacion",
      "icons": [{ "src": "/icon.svg", "sizes": "any", "type": "image/svg+xml" }]
    }
  ],
  "file_handlers": [
    {
      "action": "/?open-file=1",
      "name": "Archivo de FitSync",
      "accept": {
        "application/json": [".fitsync", ".json"]
      },
      "icons": [
        {
          "src": "/icon.svg",
          "sizes": "any",
          "type": "image/svg+xml"
        }
      ]
    }
  ],
  "launch_handler": {
    "client_mode": ["navigate-new", "focus-existing"]
  },
  "protocol_handlers": [
    {
      "protocol": "web+fitsync",
      "url": "/?uri=%s"
    }
  ],
  "share_target": {
    "action": "/?share-target=1",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "widgets": [
    {
      "name": "FitSync Resumen",
      "short_name": "Resumen",
      "description": "Ver resumen del MRR y suscripciones activas.",
      "tag": "fitsync-stats",
      "template": "stats-widget",
      "ms_ac_template": "/stats-widget.json",
      "icons": [
        {
          "src": "/icon.svg",
          "sizes": "any",
          "type": "image/svg+xml"
        }
      ]
    }
  ],
  "edge_side_panel": {
    "preferred_width": 480
  },
  "display_override": ["standalone", "minimal-ui", "window-controls-overlay"],
  "note_taking": {
    "new_note_url": "/?new-note=1"
  },
  "scope_extensions": [
    {
      "origin": "ais-dev-dzjpjxn7ex2pm26xxa4aui-106888726945.europe-west3.run.app"
    },
    {
      "origin": "ais-pre-dzjpjxn7ex2pm26xxa4aui-106888726945.europe-west3.run.app"
    }
  ]
}
